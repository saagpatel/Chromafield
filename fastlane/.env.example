# App Store Connect API key — copy to fastlane/.env and fill in real values.
# NEVER commit fastlane/.env or the .p8 private key (both are gitignored).
# Find these in App Store Connect > Users and Access > Integrations > App Store Connect API.

ASC_API_KEY_ID=XXXXXXXXXX
ASC_API_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Optional. Defaults to ~/.appstoreconnect/private_keys/AuthKey_<ASC_API_KEY_ID>.p8
# ASC_API_KEY_FILEPATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
