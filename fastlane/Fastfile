default_platform(:ios)

platform :ios do
  before_all do
    # App Store Connect API credentials are read from the environment so no
    # secrets live in source. Set ASC_API_KEY_ID and ASC_API_ISSUER_ID (e.g.
    # via fastlane/.env — see fastlane/.env.example). The .p8 private key must
    # never be committed; it lives in ~/.appstoreconnect/private_keys/.
    key_id    = ENV["ASC_API_KEY_ID"]
    issuer_id = ENV["ASC_API_ISSUER_ID"]
    key_path  = ENV["ASC_API_KEY_FILEPATH"] ||
                File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8")

    if key_id.to_s.empty? || issuer_id.to_s.empty?
      UI.user_error!("Set ASC_API_KEY_ID and ASC_API_ISSUER_ID (see fastlane/.env.example)")
    end

    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path,
      in_house: false
    )
  end

  lane :upload do
    deliver(
      skip_binary_upload: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      submit_for_review: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end
end
